RewriteEngine On

# Block directory traversal and dotfile access
RewriteCond %{REQUEST_URI} \.\. [OR]
RewriteCond %{REQUEST_URI} ^.*/\..*$
RewriteRule ^.*$ - [F,L]

# Redirect /index to home dashboard.php
RewriteRule ^index\.php$ /index [R=301,L]
RewriteRule ^index$ index.php [L]

# Redirect full URLs to clean URLs
RewriteRule ^components/login\.php$ /login [R=301,L]
RewriteRule ^components/dashboard\.php$ /dashboard [R=301,L]
RewriteRule ^logout\.php$ /logout [R=301,L]

# Redirect /patient/login.html to components/patient/login.html
RewriteRule ^patient/login\.html$ components/patient/login.html [L]
RewriteRule ^staff/login\.html$ components/staff/login.html [L]
RewriteRule ^admin/login\.html$ components/admin/login.html [L]
RewriteRule ^login\.html$ components/patient/login.html [L]

RewriteRule ^login$ components/login.php [L]
RewriteRule ^dashboard$ components/dashboard.php [L]

RewriteRule ^logout$ logout.php [L,PT]

# Block access to the account folder
RewriteRule ^account/.*$ - [F,L]

# Block access to the sql folder
RewriteRule ^sql/.*$ - [F,L]

# Block sensitive project files
RewriteRule ^(Dockerfile|compose\.yml|README\.md|cms\ 350\ db\.pdf|docs/.*)$ - [F,L]

# Error Pages
ErrorDocument 400 /error/400.html
ErrorDocument 401 /error/401.html
ErrorDocument 403 /error/403.html
ErrorDocument 404 /error/404.html
ErrorDocument 405 /error/405.html
ErrorDocument 406 /error/406.html
ErrorDocument 408 /error/408.html
ErrorDocument 409 /error/409.html
ErrorDocument 410 /error/410.html
ErrorDocument 411 /error/411.html
ErrorDocument 412 /error/412.html
ErrorDocument 413 /error/413.html
ErrorDocument 414 /error/414.html
ErrorDocument 415 /error/415.html
ErrorDocument 416 /error/416.html
ErrorDocument 417 /error/417.html
ErrorDocument 422 /error/422.html
ErrorDocument 429 /error/429.html
ErrorDocument 500 /error/500.html
ErrorDocument 502 /error/502.html
ErrorDocument 503 /error/503.html
ErrorDocument 504 /error/504.html
